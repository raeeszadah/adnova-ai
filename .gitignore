# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env & secrets (template is tracked — see `.env.example`)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript / tooling
*.tsbuildinfo
.turbo

# IDE (optional — remove if your team commits shared settings)
.idea/

# Remotion render staging (prefetched clips — not for VCS)
/public/remotion-render/*
!/public/remotion-render/.gitkeep

# Legacy / unused (project uses Convex, not Prisma client here)
/src/generated/prisma
