# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/redirect
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/redirect
CLERK_CONVEX_JWT_TEMPLATE=convex

# Admin role (Clerk Dashboard → Users → Public metadata):
#   { "role": "admin" }
#
# Clerk ↔ Convex (required for admin + Convex mutations):
# 1. Clerk → Configure → JWT Templates → add "convex" (Convex preset / integration)
# 2. Custom claim: "metadata": { "role": "{{user.public_metadata.role}}" }
# 3. Convex dashboard → Settings → Environment → CLERK_JWT_ISSUER_DOMAIN (same as above)
# 4. Sign out and sign in after template changes

# Clerk Dashboard (email/password + OTP):
# - User & Authentication → Email + Password + Google
# - Paths: sign-in /sign-in, sign-up /sign-up, after sign-in/up → /auth/redirect

# Convex — run while developing: npm run dev:convex (or npm run dev:all)
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Remotion render tuning (optional)
# REMOTION_RENDER_CONCURRENCY=2
# REMOTION_RENDER_SCALE=1

# AI APIs
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
